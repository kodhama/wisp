{
  "name": "@kodhama/wisp",
  "version": "0.2.1-rc.1",
  "private": true,
  "type": "module",
  "description": "Project-scoped runtime observability for agent teams.",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build-plugin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:container": "node scripts/run-e2e-container.mjs",
    "validate:plugin": "vitest run test/wisp-plugin-v5.test.ts",
    "verify": "npm run typecheck && npm test && npm run build && npm run validate:plugin",
    "serve": "node server.ts",
    "demo": "node demo.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "1.61.0",
    "@types/node": "^22.20.0",
    "esbuild": "0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "4.4.3"
  }
}
